# Telegram
TELEGRAM_BOT_TOKEN=replace_me
# Public bot username without @. Used by /go landing page.
TELEGRAM_BOT_USERNAME=

# Optional access lock. Empty = everyone can use the bot.
# Put comma-separated Telegram IDs, e.g. 123456789,987654321
AUTHORIZED_TELEGRAM_IDS=

# Telegram IDs that see the contextual “Admin” button on premium paywalls.
# Admin unlocks are marked separately from real payments.
CONTENT_ADMIN_IDS=

# Runtime
APP_TIMEZONE=Europe/Moscow
DATA_DIR=/app/data

# Yandex Metrica counter ID for Telegram WebApp and /go landing page.
YANDEX_METRICA_ID=
# OAuth token with access to the counter. Used to upload offline conversions by yclid.
YANDEX_METRICA_OAUTH_TOKEN=

# Railway Postgres. If set, the bot stores profiles/reports here instead of local SQLite.
DATABASE_URL=

# YooKassa payments. Railway currently uses YUKASSA_* aliases too.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Backward-compatible aliases accepted by the app:
YUKASSA_SHOP_ID=
YUKASSA_SECRET=
