# Telegram
TELEGRAM_BOT_TOKEN=replace_me

# Optional access lock. Empty = everyone can use the bot.
# Put comma-separated Telegram IDs, e.g. 123456789,987654321
AUTHORIZED_TELEGRAM_IDS=

# Runtime
APP_TIMEZONE=Europe/Moscow
DATA_DIR=/app/data


# Railway Postgres. If set, the bot stores profiles/reports here instead of local SQLite.
DATABASE_URL=

# YooKassa payments. Railway currently uses YUKASSA_* aliases too.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Backward-compatible aliases accepted by the app:
YUKASSA_SHOP_ID=
YUKASSA_SECRET=
