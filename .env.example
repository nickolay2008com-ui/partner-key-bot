# Telegram
TELEGRAM_BOT_TOKEN=replace_me

# Optional access lock. Empty = everyone can use the bot.
# Put comma-separated Telegram IDs, e.g. 123456789,987654321
AUTHORIZED_TELEGRAM_IDS=

# Runtime
APP_TIMEZONE=Europe/Moscow
DATA_DIR=/app/data

# Optional. Core MVP works without OpenAI.
# If set, the bot can polish message drafts through GPT later.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
